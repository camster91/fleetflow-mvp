# Environment variables for FleetFlow Pro
# Copy this file to .env.local for development or .env.production for production

# Next.js configuration
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# NextAuth.js Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-key-change-this-in-production

# Database Configuration (SQLite for development)
DATABASE_URL="file:./dev.db"

# Application settings
NEXT_PUBLIC_APP_NAME=FleetFlow Pro
NEXT_PUBLIC_APP_VERSION=0.1.0

# Feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_MAINTENANCE_MODE=false

# Email Configuration
# Option 1: SendGrid (Recommended for production)
SENDGRID_API_KEY=SG.xxx
EMAIL_FROM=noreply@fleetflow.io

# Option 2: Mailgun (Alternative)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-domain.com
MAILGUN_BASE_URL=https://api.mailgun.net/v3
FROM_EMAIL=FleetFlow <notifications@your-domain.com>

# Google OAuth (for social login)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft/Azure AD OAuth (for social login)
# Get credentials from: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common

# 2FA Configuration
TWO_FACTOR_ISSUER=FleetFlow Pro

# Admin Notifications
ADMIN_EMAILS=admin@your-domain.com

# API endpoints (for future backend integration)
# NEXT_PUBLIC_API_URL=https://api.fleetflow.com
# NEXT_PUBLIC_WS_URL=wss://ws.fleetflow.com

# Google Maps API (for future integration)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Security headers (configured in next.config.js)
# NEXT_PUBLIC_CSP_REPORT_ONLY=false
