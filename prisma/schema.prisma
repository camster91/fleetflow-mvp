// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Note: SQLite doesn't support native enums, so we use String with validation

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?   // Nullable for OAuth users
  role          String    @default("fleet_manager")
  company       String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Email verification
  verificationToken String? @unique

  // 2FA
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  backupCodes      String? // Hashed backup codes, JSON array

  // Password reset
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  // Login tracking
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // Social auth
  googleId    String? @unique
  microsoftId String? @unique

  // Onboarding
  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(0)

  // Notification preferences (stored as JSON string in SQLite)
  notificationPreferences String? @default("{}")

  // Session management
  sessions Session[]
  accounts Account[]

  // Login history for security audit
  loginHistory LoginHistory[]

  // Teams - User can own multiple teams and be member of multiple teams
  ownedTeams Team[]
  teamMemberships TeamMember[]

  // Notifications
  notifications Notification[]

  // API Keys
  apiKeys ApiKey[]

  // Subscription
  subscription Subscription?
  invoices Invoice[]

  // User data (vehicles, deliveries, etc.)
  userData UserData[]
  
  // Owned business data
  vehicles Vehicle[]
  deliveries Delivery[]
  maintenanceTasks MaintenanceTask[]
  clients Client[]
  sopCategories SOPCategory[]
  vendingMachines VendingMachine[]

  @@index([email])
  @@index([googleId])
  @@index([microsoftId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  // Track device info for session management
  deviceInfo   String?
  ipAddress    String?
  lastActiveAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Login history for security audit trail
model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  timestamp DateTime @default(now())
  ipAddress String?
  userAgent String?
  success   Boolean
  failureReason String?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([timestamp])
}

// Password history to prevent reuse
model PasswordHistory {
  id        String   @id @default(cuid())
  userId    String
  password  String   // Hashed password
  createdAt DateTime @default(now())

  @@index([userId])
}

// Team Management
model Team {
  id          String   @id @default(cuid())
  name        String
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  members     TeamMember[]
  
  // Relationships to team data
  vehicles     Vehicle[]
  deliveries   Delivery[]
  maintenanceTasks MaintenanceTask[]
  clients      Client[]
  sopCategories SOPCategory[]
  vendingMachines VendingMachine[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Company info
  logo          String?
  address       String?
  phone         String?
  businessHours String?
  branding      String?  // Custom colors, etc. (JSON string for SQLite)

  @@index([ownerId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   @default("MEMBER") // OWNER, ADMIN, MANAGER, MEMBER, VIEWER
  invitedBy String?
  invitedAt DateTime @default(now())
  joinedAt  DateTime?
  status    String   @default("PENDING") // PENDING, ACCEPTED, DECLINED, EXPIRED

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

// Notifications System
model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // MAINTENANCE_DUE, VEHICLE_ALERT, TEAM_INVITE, BILLING, SYSTEM, SECURITY
  title       String
  message     String
  data        String?  // Flexible data storage (JSON string for SQLite)
  read        Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

// API Keys for integrations
model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  key         String   @unique
  lastUsedAt  DateTime?
  createdAt   DateTime @default(now())
  revokedAt   DateTime?

  @@index([userId])
  @@index([key])
}

// Subscription & Billing Models
model Subscription {
  id                    String    @id @default(cuid())
  userId                String    @unique
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeCustomerId      String?   @unique
  stripeSubscriptionId  String?   @unique
  stripePriceId         String?
  plan                  String    @default("PER_USER") // PER_USER, UNLIMITED
  status                String    @default("TRIAL")   // TRIAL, ACTIVE, CANCELLED, PAST_DUE, UNPAID
  trialEndsAt           DateTime?
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAtPeriodEnd     Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

model Invoice {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeInvoiceId String   @unique
  amount          Float
  currency        String   @default("USD")
  status          String
  invoicePdf      String?
  createdAt       DateTime @default(now())
  periodStart     DateTime
  periodEnd       DateTime

  @@index([userId])
  @@index([stripeInvoiceId])
  @@index([createdAt])
}

// Core Business Models
model Vehicle {
  id              String   @id @default(cuid())
  name            String
  status          String   @default("active") // active, inactive, delayed
  driver          String?
  location        String?
  eta             String?
  mileage         Int?     @default(0)
  maintenanceDue  Boolean  @default(false)
  
  // Vehicle details
  vehicleType     String?
  licensePlate    String?
  year            Int?
  fuelLevel       Int?     @default(100) // percentage
  lastService     DateTime?
  nextService     DateTime?
  
  // Relationships
  ownerId         String
  owner           User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teamId          String?
  team            Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  
  // Related data
  deliveries      Delivery[]
  maintenanceTasks MaintenanceTask[]
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastUpdated     DateTime @default(now())
  
  // Indexes
  @@index([ownerId])
  @@index([teamId])
  @@index([status])
  @@index([maintenanceDue])
}

model Delivery {
  id                String   @id @default(cuid())
  address           String
  customer          String
  status            String   @default("pending") // pending, in-transit, delivered, cancelled
  driver            String?
  items             Int      @default(1)
  progress          Int      @default(0) // percentage
  
  // Timestamps
  scheduledTime     DateTime?
  estimatedArrival  DateTime?
  completedTime     DateTime?
  
  // Location details
  parkingInstructions String?
  dropoffInstructions String?
  
  // Contact information (stored as JSON in SQLite)
  contactPerson      String?  // JSON string: ContactPerson
  
  // Access information (stored as JSON arrays in SQLite)
  accessCodes        String?  // JSON string: string[]
  securityNotes      String?
  businessHours      String?
  specialRequirements String? // JSON string: string[]
  
  // Notes
  notes             String?
  
  // Relationships
  vehicleId         String?
  vehicle           Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  ownerId           String
  owner             User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teamId            String?
  team              Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Location coordinates (stored as JSON in SQLite)
  parkingLocation   String?  // JSON string: LocationCoordinates
  dropoffLocation   String?  // JSON string: LocationCoordinates
  
  // Photos (stored as JSON array in SQLite)
  photos            String?  // JSON string: DeliveryPhoto[]
  
  // Indexes
  @@index([ownerId])
  @@index([teamId])
  @@index([vehicleId])
  @@index([status])
  @@index([customer])
  @@index([createdAt])
}

model MaintenanceTask {
  id                String   @id @default(cuid())
  title             String
  type              String
  dueDate           DateTime
  priority          String   @default("medium") // high, medium, low
  completed         Boolean  @default(false)
  completedDate     DateTime?
  
  // Details
  notes             String?
  estimatedDuration String?
  serviceProvider   String?
  costEstimate      Float?
  
  // Relationships
  vehicleId         String
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  ownerId           String
  owner             User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teamId            String?
  team              Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  
  // Parts needed (stored as JSON array in SQLite)
  partsNeeded       String?  // JSON string: string[]
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Indexes
  @@index([ownerId])
  @@index([teamId])
  @@index([vehicleId])
  @@index([priority])
  @@index([dueDate])
  @@index([completed])
}

model Client {
  id                String   @id @default(cuid())
  name              String
  businessName      String?
  type              String   @default("other") // restaurant, hotel, office, retail, warehouse, cafe, institution, other
  address           String
  
  // Contact information
  phone             String?
  email             String?
  website           String?
  
  // Delivery preferences
  businessHours     String?
  securityNotes     String?
  
  // Notes and history
  notes             String?
  lastDeliveryDate  DateTime?
  deliveryFrequency String?  // daily, weekly, bi-weekly, monthly, as-needed
  rating            Int?     @default(5) // 1-5
  
  // Relationships
  ownerId           String
  owner             User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teamId            String?
  team              Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  
  // Contact person (stored as JSON in SQLite)
  contactPerson     String?  // JSON string: ContactPerson
  
  // Preferences (stored as JSON arrays in SQLite)
  preferredDeliveryTimes String?  // JSON string: string[]
  accessCodes            String?  // JSON string: string[]
  specialRequirements    String?  // JSON string: string[]
  
  // Location data (stored as JSON in SQLite)
  primaryLocation   String?  // JSON string: LocationCoordinates
  parkingLocation   String?  // JSON string: LocationCoordinates
  dropoffLocation   String?  // JSON string: LocationCoordinates
  
  // Instructions
  parkingInstructions  String?
  dropoffInstructions  String?
  
  // Photos (stored as JSON array in SQLite)
  locationPhotos    String?  // JSON string: DeliveryPhoto[]
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Indexes
  @@index([ownerId])
  @@index([teamId])
  @@index([type])
  @@index([name])
}

model SOPCategory {
  id                String   @id @default(cuid())
  name              String
  description       String?
  
  // Relationships
  ownerId           String
  owner             User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teamId            String?
  team              Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  
  // Count (denormalized for performance)
  documentCount     Int      @default(0)
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastUpdated       DateTime @default(now())
  
  // Indexes
  @@index([ownerId])
  @@index([teamId])
  @@index([name])
}

model VendingMachine {
  id                String   @id @default(cuid())
  name              String
  location          String
  status            String   @default("active") // active, maintenance, out-of-service
  lastService       DateTime?
  nextService       DateTime?
  
  // Details
  machineType       String?
  serialNumber      String?
  notes             String?
  
  // Relationships
  ownerId           String
  owner             User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teamId            String?
  team              Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  
  // Notes (stored as JSON array in SQLite)
  driverNotes       String?  // JSON string: VendingMachineNote[]
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Indexes
  @@index([ownerId])
  @@index([teamId])
  @@index([status])
  @@index([location])
}

// Simple key-value store for user data (temporary solution for persistence)
model UserData {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataType          String   // 'vehicles', 'deliveries', 'maintenance', 'clients', 'sop', 'vending-machines'
  data              String   // JSON string of the data
  version           Int      @default(1)
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  // Unique constraint: one data type per user
  @@unique([userId, dataType])
  
  // Indexes
  @@index([userId])
  @@index([dataType])
}
